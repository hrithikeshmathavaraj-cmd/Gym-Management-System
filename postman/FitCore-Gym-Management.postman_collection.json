{
  "info": {
    "name": "FitCore Gym Management System API",
    "description": "Complete API collection for the Gym Membership Management System. Set the {{baseUrl}} and {{token}} variables (token is auto-set after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "memberId",
      "value": ""
    },
    {
      "key": "planId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Front Desk Staff\",\n  \"username\": \"receptionist1\",\n  \"password\": \"staff123\",\n  \"role\": \"RECEPTIONIST\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.token) { pm.collectionVariables.set('token', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"newPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Plans",
      "item": [
        {
          "name": "Create Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/plans",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Quarterly\",\n  \"duration\": 90,\n  \"price\": 4999,\n  \"description\": \"3-month full access plan\"\n}"
            }
          }
        },
        {
          "name": "Get All Plans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/plans"
          }
        },
        {
          "name": "Update Plan",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/plans/{{planId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Quarterly Plus\",\n  \"duration\": 90,\n  \"price\": 5499,\n  \"description\": \"Updated plan\"\n}"
            }
          }
        },
        {
          "name": "Delete Plan",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/plans/{{planId}}"
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "Create Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) { pm.collectionVariables.set('memberId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"age\": 28,\n  \"gender\": \"Male\",\n  \"phone\": \"9876543210\",\n    \"address\": \"123 Main St\",\n  \"membershipPlan\": \"{{planId}}\"\n}"
            }
          }
        },
        {
          "name": "Get All Members (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members?page=0&size=10&sortBy=createdAt&direction=desc"
          }
        },
        {
          "name": "Search Members",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/search?keyword=john&page=0&size=10"
          }
        },
        {
          "name": "Get Member By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/{{memberId}}"
          }
        },
        {
          "name": "Update Member",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/{{memberId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Jr\",\n  \"age\": 29,\n  \"gender\": \"Male\",\n  \"phone\": \"9876543210\",\n    \"address\": \"456 New St\",\n  \"membershipPlan\": \"{{planId}}\"\n}"
            }
          }
        },
        {
          "name": "Renew Membership",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/{{memberId}}/renew?planId={{planId}}"
          }
        },
        {
          "name": "Get Member QR Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/{{memberId}}/qrcode"
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/members/{{memberId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"amount\": 4999,\n  \"paymentMethod\": \"UPI\"\n}"
            }
          }
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Get Payments By Member",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/payments/member/{{memberId}}"
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Check In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/attendance/check-in?memberId={{memberId}}"
          }
        },
        {
          "name": "Check Out",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/attendance/check-out?memberId={{memberId}}"
          }
        },
        {
          "name": "Today's Attendance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/attendance/today"
          }
        },
        {
          "name": "Monthly Attendance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/attendance/monthly?year=2026&month=7"
          }
        }
      ]
    },
